APP_KEY=base64:replace-with-php-artisan-key-generate-show
EDGE_ARTIFACT_SIGNING_KEY=replace-with-a-separate-high-entropy-signing-seed
APP_URL=https://control.example.com
CONTROL_BIND=127.0.0.1:8080
CONTROL_DB_PASSWORD=replace-me
REDIS_PASSWORD=replace-me
PDNS_DB_PASSWORD=replace-me
PDNS_API_KEY=replace-me
CLICKHOUSE_PASSWORD=replace-me
DNS_BIND_V4=0.0.0.0
EDGE_HTTP_BIND=0.0.0.0:80
EDGE_HTTPS_BIND=0.0.0.0:443
EDGE_RUNTIME_TLS_CERTIFICATE=/absolute/path/to/edge-runtime.crt
EDGE_RUNTIME_TLS_PRIVATE_KEY=/absolute/path/to/edge-runtime.key
CDNF_CORE_IMAGE=cdnfoundry/core:local
CDNF_MMDB_UPDATER_IMAGE=cdnfoundry/mmdb-updater:local
CDNF_EDGE_AGENT_IMAGE=cdnfoundry/edge-agent:local
EDGE_CONTROL_URL=https://control.example.com
EDGE_CONTROL_BIND=0.0.0.0:8443
EDGE_CONTROL_SERVER_CERTIFICATE=/absolute/path/to/edge-control-server.crt
EDGE_CONTROL_SERVER_PRIVATE_KEY=/absolute/path/to/edge-control-server.key
EDGE_IDENTITY_CA_CERTIFICATE=/absolute/path/to/edge-identity-ca.crt
EDGE_IDENTITY_CA_PRIVATE_KEY=/absolute/path/to/edge-identity-ca.key
EDGE_IDENTITY_CA_PRIVATE_KEY_PASSPHRASE=
EDGE_ID=
EDGE_BOOTSTRAP_TOKEN=
EDGE_STATUS_TOKEN=replace-with-a-separate-high-entropy-status-token
MMDB_PROVIDER=dbip-jsdelivr
MMDB_TARGET_FILE=GeoLite2-City.mmdb
MMDB_DOWNLOAD_INTERVAL_SECONDS=86400
MMDB_DOWNLOAD_RETRIES=5
MMDB_EXPECTED_SHA256=
MMDB_DOWNLOAD_URL=
MMDB_DOWNLOAD_HEADER=
