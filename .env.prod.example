# CDNFoundry production environment template
# Copy to .env.prod, keep mode 0600, and never commit it.
# Labels: [required] must be set for the owning profile/service; [optional] may remain empty.

# -----------------------------------------------------------------------------
# Control plane — owned by core, web, horizon, scheduler, and migrate
# -----------------------------------------------------------------------------
# [required] Generate with: docker compose run --rm core php artisan key:generate --show
APP_KEY=base64:replace-with-php-artisan-key-generate-show
# [required] Separate high-entropy signing seed; never reuse APP_KEY or a password.
EDGE_ARTIFACT_SIGNING_KEY=replace-with-a-separate-high-entropy-signing-seed
# [required] Public canonical control-panel URL. HTTPS is strongly recommended.
APP_URL=https://control.example.com
# [required behind HTTPS] Prevent browser sessions from being sent over plaintext HTTP.
SESSION_SECURE_COOKIE=true
# [optional] Host listener for the web UI/API. Keep loopback when a host reverse proxy terminates public TLS.
CONTROL_BIND=127.0.0.1:8080
# [required with deploy/production/compose.control-host.yml] Public control-panel hostname served by Caddy.
CONTROL_HOSTNAME=control.example.com
# [required with the control-host override] Public TLS hostname used only for edge telemetry ingestion.
TELEMETRY_HOSTNAME=telemetry.example.com
# [required on DNS API gateways] Control/worker sources allowed to reconcile DNS.
CONTROL_PUBLIC_IPV4_ALLOWLIST=
# [required on telemetry gateways] Edge/Vector sources allowed to ingest events.
EDGE_PUBLIC_IPV4_ALLOWLIST=
# [required] Unique high-entropy secrets owned by the named database/service.
CONTROL_DB_PASSWORD=replace-with-a-unique-high-entropy-control-db-password
REDIS_PASSWORD=replace-with-a-unique-high-entropy-valkey-password
# [optional] External replicated dependency endpoints for split control/worker hosts.
# Require TLS and exact-source firewalls when these cross public networks.
DB_URL=
DB_HOST=control-db
DB_PORT=5432
DB_SSLMODE=prefer
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
# [required for control and telemetry profiles] Absolute path to a mode-0600 file containing one random metrics bearer token.
METRICS_TOKEN_FILE=/etc/cdnfoundry/secrets/metrics-token

# [required] Encrypted off-host Restic repository. S3 credentials should permit only this backup prefix.
RESTIC_REPOSITORY=s3:https://s3.example.com/cdnfoundry-control
RESTIC_PASSWORD_FILE=/etc/cdnfoundry/secrets/restic-password
BACKUP_ACCESS_KEY_ID=replace-with-backup-only-access-key
BACKUP_SECRET_ACCESS_KEY=replace-with-backup-only-secret-key
BACKUP_DEFAULT_REGION=us-east-1

# [required] ACME account contact. Expiry and validation notices go to this address and the admin panel.
ACME_CONTACT_EMAIL=cdn-operations@example.com
# [optional] Override only for a compatible production CA directory or staging qualification.
ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
# [optional] Global new-order ceiling shared by all certificate workers.
ACME_ORDER_BUDGET_PER_HOUR=20

# -----------------------------------------------------------------------------
# Authoritative DNS — owned by pdns-db, pdns-auth, and dnsdist
# -----------------------------------------------------------------------------
# [required] Use distinct high-entropy values; PDNS_API_KEY is a private control-plane credential.
PDNS_DB_PASSWORD=replace-with-a-unique-high-entropy-pdns-db-password
PDNS_API_KEY=replace-with-a-unique-high-entropy-pdns-api-key
# [optional] Public DNS bind address. 0.0.0.0 exposes authoritative DNS on every IPv4 interface.
DNS_BIND_V4=0.0.0.0

# -----------------------------------------------------------------------------
# Telemetry — owned by ClickHouse
# -----------------------------------------------------------------------------
# [required for telemetry profile] Unique high-entropy ClickHouse password.
CLICKHOUSE_PASSWORD=replace-with-a-unique-high-entropy-clickhouse-password
# Use the container endpoint when ClickHouse is local, or a verified HTTPS endpoint for a split/clustered telemetry deployment.
CLICKHOUSE_URL=http://clickhouse:8123

# -----------------------------------------------------------------------------
# Container images — owned by Compose on hosts running the corresponding profile
# -----------------------------------------------------------------------------
# [required] Exact 40-character Git commit SHA (recommended) or exact vMAJOR.MINOR.PATCH release tag.
# Do not deploy the mutable latest, major, or minor channel tags in production.
CDNF_RELEASE=0000000000000000000000000000000000000000
# [required only with deploy/production multi-host overrides] Public addresses owned by this host.
PUBLIC_BIND_IPV4=
PUBLIC_BIND_IPV6=

# -----------------------------------------------------------------------------
# Edge-control mutual TLS — owned by edge-control and core
# See docs/operations/production-certificates.md and scripts/generate-production-certificates.sh.
# -----------------------------------------------------------------------------
# [required for control profile] Public URL agents use; certificate SAN must match its hostname.
EDGE_CONTROL_URL=https://edge-control.example.com:8443
# [optional] Agent-control listener. Restrict with a firewall to registered edge networks where practical.
EDGE_CONTROL_BIND=0.0.0.0:8443
# [required] Absolute host paths. Keep private keys mode 0600 and outside the repository.
EDGE_CONTROL_SERVER_CERTIFICATE=/etc/cdnfoundry/pki/edge-control-server.crt
EDGE_CONTROL_SERVER_PRIVATE_KEY=/etc/cdnfoundry/pki/edge-control-server.key
# [required on edge-agent hosts using the generated/private server CA] Public trust anchor; never copy its key.
EDGE_CONTROL_CA_CERTIFICATE=/etc/cdnfoundry/pki/edge-server-ca.crt
EDGE_IDENTITY_CA_CERTIFICATE=/etc/cdnfoundry/pki/edge-identity-ca.crt
# The PHP-FPM worker must be able to read this without making it world-readable.
# For the shipped image use root:82 and mode 0640; see the certificate runbook.
EDGE_IDENTITY_CA_PRIVATE_KEY=/etc/cdnfoundry/pki/edge-identity-ca.key
# [required for HTTPS PowerDNS APIs] Server-CA certificate used by Horizon to verify DNS API proxies.
PDNS_CA_CERTIFICATE=/etc/cdnfoundry/pki/edge-server-ca.crt
# [optional] Set only when the CA private key is encrypted and the deployment supplies the passphrase securely.
EDGE_IDENTITY_CA_PRIVATE_KEY_PASSPHRASE=

# -----------------------------------------------------------------------------
# Public edge runtime — owned by edge and edge-quarantine
# -----------------------------------------------------------------------------
# [optional] Public listeners. Use explicit service IPs instead of every interface when possible.
EDGE_HTTP_BIND=0.0.0.0:80
EDGE_HTTPS_BIND=0.0.0.0:443
# [optional] Quarantine owns distinct service addresses. Bind these ports to that
# pool's public IPv4/IPv6 using host routing or a production Compose override.
EDGE_QUARANTINE_HTTP_BIND=127.0.0.1:18080
EDGE_QUARANTINE_HTTPS_BIND=127.0.0.1:18443
# [required for edge profile] Bootstrap/default listener certificate and key, absolute host paths.
EDGE_RUNTIME_TLS_CERTIFICATE=/etc/cdnfoundry/pki/edge-runtime.crt
EDGE_RUNTIME_TLS_PRIVATE_KEY=/etc/cdnfoundry/pki/edge-runtime.key
# [required for edge profile] Separate high-entropy token protecting the private cell-status endpoint.
EDGE_STATUS_TOKEN=replace-with-a-separate-high-entropy-status-token
# [required with deploy/production/compose.dns-edge-host.yml] Per-host DNS API TLS identity.
DNS_API_HOSTNAME=dns-api.example.com
DNS_API_SERVER_CERTIFICATE=/etc/cdnfoundry/pki/dns-api.crt
DNS_API_SERVER_PRIVATE_KEY=/etc/cdnfoundry/pki/dns-api.key

# -----------------------------------------------------------------------------
# Edge-agent enrollment — owned by edge-agent on each edge host
# -----------------------------------------------------------------------------
# [required on first enrollment] UUID and one-time token returned when the administrator creates the edge.
# After successful registration the agent persists its identity; remove the bootstrap token from .env.prod.
EDGE_ID=
EDGE_BOOTSTRAP_TOKEN=

# -----------------------------------------------------------------------------
# GeoIP database updater — owned by mmdb-updater
# -----------------------------------------------------------------------------
# [optional] dbip-jsdelivr is the zero-credential default. Use custom only with URL/header below.
MMDB_PROVIDER=dbip-jsdelivr
# [optional] Keep the runtime filename unless all GEOIP_DATABASE consumers are changed together.
MMDB_TARGET_FILE=GeoLite2-City.mmdb
# [optional] Recommended daily refresh; minimum operational value depends on provider terms.
MMDB_DOWNLOAD_INTERVAL_SECONDS=86400
MMDB_DOWNLOAD_RETRIES=5
# [optional but recommended with a pinned/custom artifact] Lowercase SHA-256 checksum.
MMDB_EXPECTED_SHA256=
# [required only when MMDB_PROVIDER=custom] HTTPS download URL and optional authorization header.
MMDB_DOWNLOAD_URL=
MMDB_DOWNLOAD_HEADER=
