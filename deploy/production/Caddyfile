{
	admin off
	email {$ACME_CONTACT_EMAIL}
}

{$CONTROL_HOSTNAME} {
	encode zstd gzip
	reverse_proxy web:8080

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

https://{$TELEMETRY_HOSTNAME}:8444 {
	@edge_sources remote_ip {$EDGE_PUBLIC_IPV4_ALLOWLIST}

	handle @edge_sources {
		reverse_proxy clickhouse:8123
	}

	respond 403
}

http://127.0.0.1:2019 {
	respond /healthz 200
}
