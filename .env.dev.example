# Copy to .env.dev only when enrolling UI-created edges in the local stack.
# Values are one-time credentials. Never commit the populated file.
CDNF_DEV_EDGE_A_ID=
CDNF_DEV_EDGE_A_BOOTSTRAP_TOKEN=
CDNF_DEV_EDGE_B_ID=
CDNF_DEV_EDGE_B_BOOTSTRAP_TOKEN=

# Development-only shared secret for agent-to-runtime status/control calls.
CDNF_DEV_EDGE_STATUS_TOKEN=cdnf-dev-edge-status-only
